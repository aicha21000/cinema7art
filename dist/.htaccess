# Enable CORS and Headers
<IfModule mod_headers.c>
    # Permettre à Facebook de lire les meta tags
    <FilesMatch "\.(html|php)$">
        Header set X-Frame-Options "ALLOW-FROM https://www.facebook.com/"
        Header set Access-Control-Allow-Origin "*"
        Header unset Cache-Control
        Header unset Pragma
        Header unset Expires
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>

    # Headers pour les images
    <FilesMatch "\.(jpg|jpeg|png|gif)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=31536000"
        Header set X-Content-Type-Options "nosniff"
        Header set Content-Type "image/jpeg"
    </FilesMatch>
</IfModule>

# URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Si le fichier demandé n'existe pas, redirige vers index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteRule . /index.html [L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Redirection www vers non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# Compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Protection du fichier .htaccess
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# Désactiver l'affichage du contenu des répertoires
Options -Indexes

# Définir le jeu de caractères par défaut
AddDefaultCharset UTF-8

# Définir la page d'erreur 404
ErrorDocument 404 /index.html 